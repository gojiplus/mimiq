{
  "name": "@gojiplus/mimiq",
  "version": "0.5.0",
  "description": "Simulate users and evaluate AI agents in Cypress and Playwright e2e tests",
  "type": "module",
  "workspaces": [
    "examples/playwright",
    "examples/cypress",
    "examples/stagehand"
  ],
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./node": {
      "types": "./dist/node/index.d.ts",
      "default": "./dist/node/index.js"
    },
    "./cypress": {
      "types": "./dist/adapters/cypress/index.d.ts",
      "default": "./dist/adapters/cypress/index.js"
    },
    "./playwright": {
      "types": "./dist/adapters/playwright/index.d.ts",
      "default": "./dist/adapters/playwright/index.js"
    },
    "./simulators": {
      "types": "./dist/simulators/index.d.ts",
      "default": "./dist/simulators/index.js"
    }
  },
  "bin": {
    "mimiq": "./dist/cli/index.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src --ext .ts",
    "dev:app": "npm run dev --prefix test/app",
    "test:cypress": "npm test --prefix examples/cypress-basic",
    "test:playwright": "npm test --prefix examples/playwright-basic",
    "test": "npm run test:playwright",
    "test:agent": "cd examples && npx mimiq agent --scenes ./agent-scenes --headless",
    "demo:agent": "cd examples && npx mimiq agent --scenes ./agent-scenes --no-headless",
    "docs": "typedoc"
  },
  "peerDependencies": {
    "@browserbasehq/stagehand": "^3.0.0",
    "@playwright/test": "^1.40.0",
    "cypress": "^14.0.0"
  },
  "peerDependenciesMeta": {
    "cypress": {
      "optional": true
    },
    "@playwright/test": {
      "optional": true
    },
    "@browserbasehq/stagehand": {
      "optional": true
    }
  },
  "devDependencies": {
    "@browserbasehq/stagehand": "^3.2.1",
    "@playwright/test": "^1.59.1",
    "@types/node": "^22.19.15",
    "@types/nunjucks": "^3.2.6",
    "@types/pino": "^7.0.4",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "cypress": "^14.0.0",
    "dotenv": "^17.3.1",
    "eslint": "^8.0.0",
    "pino-pretty": "^13.1.3",
    "tsup": "^8.0.0",
    "typedoc": "^0.28.17",
    "typescript": "^5.4.0",
    "yaml": "^2.8.2"
  },
  "keywords": [
    "cypress",
    "playwright",
    "testing",
    "e2e",
    "agent",
    "simulation",
    "mimiq",
    "llm",
    "chatbot",
    "browser-agent"
  ],
  "author": "Gaurav Sood",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/gojiplus/mimiq.git"
  },
  "bugs": {
    "url": "https://github.com/gojiplus/mimiq/issues"
  },
  "homepage": "https://github.com/gojiplus/mimiq#readme",
  "dependencies": {
    "@ai-sdk/anthropic": "^3.0.58",
    "@ai-sdk/google": "^3.0.43",
    "@ai-sdk/openai": "^3.0.41",
    "ai": "^6.0.116",
    "commander": "^14.0.3",
    "nunjucks": "^3.2.4",
    "pino": "^10.3.1"
  },
  "overrides": {
    "playwright": "$@playwright/test"
  }
}
